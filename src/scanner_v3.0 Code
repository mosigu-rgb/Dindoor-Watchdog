"""
DINDOOR SMART WATCHDOG - Version 3.0
Verbesserungen gegenüber v2:
  ✅ n_jobs=-1        → Alle CPU-Kerne parallel
  ✅ joblib Caching   → Modell wird gespeichert & wiederverwendet
  ✅ Ensemble-Modell  → IsolationForest + LocalOutlierFactor
  ✅ Feature Engineering → cpu_spike, req_burst, packet_entropy
"""

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from sklearn.ensemble import IsolationForest
from sklearn.neighbors import LocalOutlierFactor
from sklearn.metrics import confusion_matrix, classification_report, ConfusionMatrixDisplay
from sklearn.preprocessing import StandardScaler
import joblib
import os
import time
import warnings
warnings.filterwarnings("ignore")

np.random.seed(42)

MODEL_CACHE_PATH  = "watchdog_model.pkl"
SCALER_CACHE_PATH = "watchdog_scaler.pkl"

# ─────────────────────────────────────────────
# 1. SYNTHETISCHE TRAININGSDATEN
# ─────────────────────────────────────────────

def generate_data(n_normal=800, n_attack=100):
    # Normaler Traffic
    normal = np.column_stack([
        np.random.normal(40, 15, n_normal).clip(0, 100),
        np.random.normal(900, 200, n_normal).clip(100, 1500),
        np.random.normal(20, 8, n_normal).clip(1, 100),
        np.random.binomial(1, 0.15, n_normal),
        np.random.normal(300, 120, n_normal).clip(10, 900),
        np.random.normal(38, 10, n_normal).clip(0, 100),   # cpu_mean_60s
        np.random.normal(19, 6,  n_normal).clip(1, 80),    # req_mean_5min
    ])

    # Angriffs-Traffic
    attacks = np.column_stack([
        np.random.normal(88, 8, n_attack).clip(70, 100),
        np.random.normal(1800, 300, n_attack).clip(1400, 9000),
        np.random.normal(120, 30, n_attack).clip(50, 300),
        np.random.binomial(1, 0.75, n_attack),
        np.random.normal(30, 15, n_attack).clip(5, 120),
        np.random.normal(39, 10, n_attack).clip(0, 100),
        np.random.normal(18, 5,  n_attack).clip(1, 40),
    ])

    X_raw  = np.vstack([normal, attacks])
    y_true = np.array([1] * n_normal + [-1] * n_attack)
    return X_raw, y_true


# ─────────────────────────────────────────────
# 2. FEATURE ENGINEERING
# ─────────────────────────────────────────────

def engineer_features(X_raw):
    cpu_load       = X_raw[:, 0]
    packet_size    = X_raw[:, 1]
    req_per_sec    = X_raw[:, 2]
    vpn_score      = X_raw[:, 3]
    session_length = X_raw[:, 4]
    cpu_mean_60s   = X_raw[:, 5]
    req_mean_5min  = X_raw[:, 6]

    cpu_spike      = np.abs(cpu_load - cpu_mean_60s)
    req_burst      = req_per_sec / np.clip(req_mean_5min, 1, None)
    packet_median  = np.median(packet_size)
    packet_entropy = np.abs(packet_size - packet_median) / (packet_median + 1)

    X_eng = np.column_stack([
        cpu_load, packet_size, req_per_sec, vpn_score, session_length,
        cpu_spike, req_burst, packet_entropy,
    ])
    return X_eng

FEATURE_NAMES = [
    "cpu_load", "packet_size", "req_per_sec", "vpn_score", "session_length",
    "cpu_spike", "req_burst", "packet_entropy"
]

# ─────────────────────────────────────────────
# 3. DATEN VORBEREITEN
# ─────────────────────────────────────────────

X_raw, y_true = generate_data()
X_eng = engineer_features(X_raw)

# ─────────────────────────────────────────────
# 4. JOBLIB CACHING
# ─────────────────────────────────────────────

FORCE_RETRAIN = False

if os.path.exists(MODEL_CACHE_PATH) and not FORCE_RETRAIN:
    print("⚡ Cache gefunden – lade gespeichertes Modell...")
    iso_model  = joblib.load(MODEL_CACHE_PATH)
    scaler     = joblib.load(SCALER_CACHE_PATH)
    X_scaled   = scaler.transform(X_eng)
    cache_used = True
else:
    print("🔧 Kein Cache – trainiere Modelle neu...")
    t_start  = time.time()
    scaler   = StandardScaler()
    X_scaled = scaler.fit_transform(X_eng.astype(np.float32))

    iso_model = IsolationForest(
        n_estimators=200,
        contamination=0.11,
        max_features=1.0,
        n_jobs=-1,
        random_state=42
    )
    iso_model.fit(X_scaled)

    joblib.dump(iso_model, MODEL_CACHE_PATH)
    joblib.dump(scaler,    SCALER_CACHE_PATH)
    print(f"✅ Training in {time.time() - t_start:.2f}s – Cache gespeichert.")
    cache_used = False

# ─────────────────────────────────────────────
# 5. ENSEMBLE: IsolationForest + LocalOutlierFactor
# ─────────────────────────────────────────────

lof_model = LocalOutlierFactor(
    n_neighbors=20, contamination=0.11,
    novelty=True, n_jobs=-1
)
lof_model.fit(X_scaled)

def ensemble_predict(X_input):
    pred_iso     = iso_model.predict(X_input)
    pred_lof     = lof_model.predict(X_input)
    score_iso    = iso_model.decision_function(X_input)
    score_lof    = lof_model.decision_function(X_input)
    combined     = (score_iso + score_lof) / 2
    final_pred   = np.where((pred_iso == -1) & (pred_lof == -1), -1, 1)
    return final_pred, combined, pred_iso, pred_lof

y_pred, anomaly_scores, y_iso, y_lof = ensemble_predict(X_scaled)

# ─────────────────────────────────────────────
# 6. KONSOLEN-OUTPUT
# ─────────────────────────────────────────────

print("\n" + "=" * 60)
print("   DINDOOR SMART WATCHDOG v3.0 – Ensemble + Feature Eng.")
print("=" * 60)
print(f"\nTrainingsdaten : {len(X_eng)} Datenpunkte")
print(f"Features       : {len(FEATURE_NAMES)} ({', '.join(FEATURE_NAMES)})")
print(f"Cache genutzt  : {'Ja ⚡' if cache_used else 'Nein (neu trainiert)'}")

print("\n--- EINZEL-MODELL PERFORMANCE ---")
print("IsolationForest:")
print(classification_report(y_true, y_iso, target_names=["Angriff", "Normal"], zero_division=0))
print("LocalOutlierFactor:")
print(classification_report(y_true, y_lof, target_names=["Angriff", "Normal"], zero_division=0))
print("--- ENSEMBLE PERFORMANCE ---")
print(classification_report(y_true, y_pred, target_names=["Angriff", "Normal"], zero_division=0))

# Live-Analyse
new_access_raw = np.array([[85, 1800, 110, 1, 25, 39, 18]])
new_access_eng = engineer_features(new_access_raw)
x_new_scaled   = scaler.transform(new_access_eng.astype(np.float32))
pred_new, score_new, iso_new, lof_new = ensemble_predict(x_new_scaled)

print("\n--- LIVE ANALYSE: Neuer Zugriff ---")
for i, label in enumerate(["cpu_load","packet_size","req_per_sec","vpn_score","session_length"]):
    print(f"  {label:<18}: {new_access_raw[0, i]}")
print(f"\n  cpu_spike         : {new_access_eng[0, 5]:.2f}")
print(f"  req_burst         : {new_access_eng[0, 6]:.2f}x")
print(f"  packet_entropy    : {new_access_eng[0, 7]:.4f}")
print(f"\n  IsolationForest   : {'🔴 Anomalie' if iso_new[0] == -1 else '🟢 Normal'}")
print(f"  LocalOutlierFactor: {'🔴 Anomalie' if lof_new[0] == -1 else '🟢 Normal'}")
print(f"  Ensemble Score    : {score_new[0]:.4f}")
print(f"  Entscheidung      : {'🔴 BLOCK ACCESS' if pred_new[0] == -1 else '🟢 ALLOW ACCESS'}")
print("=" * 60)

# ─────────────────────────────────────────────
# 7. VISUALISIERUNG
# ─────────────────────────────────────────────

fig = plt.figure(figsize=(18, 12), facecolor="#0f1117")
fig.suptitle("DINDOOR SMART WATCHDOG v3.0 — Ensemble + Feature Engineering",
             color="white", fontsize=16, fontweight="bold", y=0.98)

gs = gridspec.GridSpec(2, 3, figure=fig, hspace=0.45, wspace=0.35)

COLORS = {
    "normal_true": "#00d4aa", "attack_true": "#ff4f4f",
    "normal_pred": "#00aaff", "attack_pred": "#ff9900",
    "bg": "#1a1d27", "grid": "#2e3047", "text": "#e0e0e0",
}

def style_ax(ax, title):
    ax.set_facecolor(COLORS["bg"])
    ax.set_title(title, color=COLORS["text"], fontsize=10, pad=10)
    ax.tick_params(colors=COLORS["text"])
    ax.xaxis.label.set_color(COLORS["text"])
    ax.yaxis.label.set_color(COLORS["text"])
    for spine in ax.spines.values():
        spine.set_edgecolor(COLORS["grid"])
    ax.grid(True, color=COLORS["grid"], linewidth=0.5, alpha=0.6)

mask_n = y_true == 1
mask_a = y_true == -1

# Plot 1: cpu_spike vs req_burst
ax1 = fig.add_subplot(gs[0, 0])
style_ax(ax1, "cpu_spike vs. req_burst\n(Engineered Features – Ground Truth)")
ax1.scatter(X_eng[mask_n, 5], X_eng[mask_n, 6], c=COLORS["normal_true"], alpha=0.4, s=12, label="Normal")
ax1.scatter(X_eng[mask_a, 5], X_eng[mask_a, 6], c=COLORS["attack_true"], alpha=0.8, s=20, label="Angriff")
ax1.scatter(new_access_eng[0,5], new_access_eng[0,6], c="white", s=150, marker="*", zorder=5, label="Neuer Zugriff")
ax1.set_xlabel("cpu_spike"); ax1.set_ylabel("req_burst")
ax1.legend(facecolor=COLORS["bg"], labelcolor=COLORS["text"], fontsize=8)

# Plot 2: Ensemble-Entscheidung
ax2 = fig.add_subplot(gs[0, 1])
style_ax(ax2, "Ensemble-Entscheidung\n(ISO + LOF)")
ax2.scatter(X_eng[y_pred==1, 0], X_eng[y_pred==1, 1], c=COLORS["normal_pred"], alpha=0.4, s=12, label="Normal")
ax2.scatter(X_eng[y_pred==-1,0], X_eng[y_pred==-1,1], c=COLORS["attack_pred"], alpha=0.8, s=20, label="Anomalie")
ax2.scatter(new_access_raw[0,0], new_access_raw[0,1], c="white", s=150, marker="*", zorder=5, label="Neuer Zugriff")
ax2.set_xlabel("CPU Load (%)"); ax2.set_ylabel("Packet Size (Bytes)")
ax2.legend(facecolor=COLORS["bg"], labelcolor=COLORS["text"], fontsize=8)

# Plot 3: Score-Verteilung
ax3 = fig.add_subplot(gs[0, 2])
style_ax(ax3, "Ensemble Score-Verteilung")
bins = np.linspace(anomaly_scores.min(), anomaly_scores.max(), 50)
ax3.hist(anomaly_scores[y_true== 1], bins=bins, color=COLORS["normal_true"], alpha=0.7, label="Normal")
ax3.hist(anomaly_scores[y_true==-1], bins=bins, color=COLORS["attack_true"],  alpha=0.7, label="Angriff")
ax3.axvline(score_new[0], color="white", linestyle="--", lw=1.5, label=f"Neuer Zugriff ({score_new[0]:.3f})")
ax3.axvline(0, color="#ffff00", linestyle=":", lw=1, alpha=0.7, label="Threshold")
ax3.set_xlabel("Combined Score"); ax3.set_ylabel("Anzahl")
ax3.legend(facecolor=COLORS["bg"], labelcolor=COLORS["text"], fontsize=8)

# Plot 4: Confusion Matrix
ax4 = fig.add_subplot(gs[1, 0])
ax4.set_facecolor(COLORS["bg"])
cm   = confusion_matrix(y_true, y_pred, labels=[-1, 1])
disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=["Angriff", "Normal"])
disp.plot(ax=ax4, colorbar=False, cmap="Blues")
ax4.set_title("Confusion Matrix – Ensemble", color=COLORS["text"], fontsize=10, pad=10)
ax4.tick_params(colors=COLORS["text"])
ax4.xaxis.label.set_color(COLORS["text"]); ax4.yaxis.label.set_color(COLORS["text"])
for spine in ax4.spines.values(): spine.set_edgecolor(COLORS["grid"])
for text in ax4.texts: text.set_color("black")

# Plot 5: ISO vs LOF Disagreement
ax5 = fig.add_subplot(gs[1, 1])
agree    = (y_iso == y_lof)
disagree = ~agree
ax5.scatter(X_eng[agree,   0], X_eng[agree,   1], c=COLORS["normal_pred"], alpha=0.3, s=10, label="Einig")
ax5.scatter(X_eng[disagree,0], X_eng[disagree,1], c="#ffff00", alpha=0.9, s=30, label="Uneinig ⚠️")
ax5.set_xlabel("CPU Load (%)"); ax5.set_ylabel("Packet Size (Bytes)")
ax5.legend(facecolor=COLORS["bg"], labelcolor=COLORS["text"], fontsize=9)
ax5.set_title(f"ISO vs. LOF Disagreement\n({disagree.sum()} von {len(y_true)} Punkten)",
              color=COLORS["text"], fontsize=10, pad=10)
for spine in ax5.spines.values(): spine.set_edgecolor(COLORS["grid"])
ax5.set_facecolor(COLORS["bg"]); ax5.tick_params(colors=COLORS["text"])
ax5.grid(True, color=COLORS["grid"], linewidth=0.5, alpha=0.6)

# Plot 6: Feature Importance
ax6 = fig.add_subplot(gs[1, 2])
style_ax(ax6, "Feature Importance\n(Permutation-Proxy)")
base_score  = np.mean(np.abs(iso_model.decision_function(X_scaled)))
importances = []
for i in range(X_scaled.shape[1]):
    X_perm = X_scaled.copy()
    np.random.shuffle(X_perm[:, i])
    importances.append(abs(np.mean(np.abs(iso_model.decision_function(X_perm))) - base_score))

importances = np.array(importances) / (np.sum(importances) + 1e-9)
sorted_idx  = np.argsort(importances)
eng_indices = {5, 6, 7}
bar_colors  = [COLORS["attack_true"] if sorted_idx[i] in eng_indices else COLORS["normal_pred"]
               for i in range(len(sorted_idx))]
bars = ax6.barh([FEATURE_NAMES[i] for i in sorted_idx], importances[sorted_idx],
                color=bar_colors, edgecolor=COLORS["grid"])
ax6.set_xlabel("Relative Wichtigkeit")
for bar, val in zip(bars, importances[sorted_idx]):
    ax6.text(val + 0.003, bar.get_y() + bar.get_height()/2,
             f"{val:.3f}", va="center", color=COLORS["text"], fontsize=9)

from matplotlib.patches import Patch
ax6.legend(handles=[
    Patch(facecolor=COLORS["attack_true"], label="Engineered Feature (neu)"),
    Patch(facecolor=COLORS["normal_pred"], label="Original Feature"),
], facecolor=COLORS["bg"], labelcolor=COLORS["text"], fontsize=8, loc="lower right")

plt.savefig("dindoor_watchdog_v3.png", dpi=150, bbox_inches="tight", facecolor=fig.get_facecolor())
print("\n✅ Visualisierung gespeichert als dindoor_watchdog_v3.png")
plt.close()
